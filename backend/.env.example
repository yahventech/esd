# EASD backend — environment template.
# Copy to `.env` and fill in values. Everything here is read by easd_backend/settings.py
# via python-dotenv; missing keys fall back to dev-safe defaults so partial
# config still boots.

# ─── Django core ────────────────────────────────────────────
# Generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=esd-biau.onrender.com
DJANGO_TIME_ZONE=Africa/Nairobi

# ─── CORS / CSRF ────────────────────────────────────────────
# Dev: keep DJANGO_CORS_ALLOW_ALL=1 so the Vite dev server can hit you freely.
# Production: set it to 0 and list explicit https origins below.
DJANGO_CORS_ALLOW_ALL=0
DJANGO_CORS_ALLOW_CREDENTIALS=1
DJANGO_CORS_ALLOWED_ORIGINS=https://ea-sportsdesk.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ea-sportsdesk.com

FRONTEND_BASE_URL=https://ea-sportsdesk.com

# ─── JWT lifetimes ──────────────────────────────────────────
JWT_ACCESS_HOURS=12
JWT_REFRESH_DAYS=14

# ─── Live score sync (API-Football) ─────────────────────────
# Get a free key: https://dashboard.api-football.com/register (100 req/day)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io
LIVE_SYNC_AUTO=1
LIVE_SYNC_INTERVAL_SECONDS=60

# ─── Database ────────────────────────────────────────────────
# Use PostgreSQL in production. Falls back to SQLite for dev.
# Example: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///db.sqlite3

# ─── Cloudflare R2 media storage ─────────────────────────────
# Use Cloudflare R2 for Django file uploads. Set the bucket name, keys,
# and endpoint in production. If your R2 endpoint is bucket-specific,
# set AWS_S3_CUSTOM_DOMAIN instead of AWS_S3_ENDPOINT_URL.
# catalog URI: https://catalog.cloudflarestorage.com/ff5f39e29f9f320158283a770dd2f145/easd
# public URL: https://pub-acac0a4d8fc64b5c9268945d8a688244.r2.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=easd
AWS_S3_ENDPOINT_URL=https://ff5f39e29f9f320158283a770dd2f145.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_CUSTOM_DOMAIN=pub-acac0a4d8fc64b5c9268945d8a688244.r2.dev
AWS_LOCATION=media
DJANGO_DEFAULT_FILE_STORAGE=
DJANGO_MEDIA_URL=

# ─── Logging ─────────────────────────────────────────────
# Set to DEBUG for detailed logs, INFO for normal operation, WARNING for production
DJANGO_LOG_LEVEL=INFO
