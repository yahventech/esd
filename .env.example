# EASD frontend (Vite) — environment template.
# Copy to `.env` for local dev. Variables prefixed with VITE_ are inlined into
# the bundle at build time.

# Base URL for the Django REST API + WebSocket server.
#   dev:        http://127.0.0.1:8000
#   staging:    https://api.staging.easd.example.com
#   production: https://esd-biau.onrender.com
VITE_API_URL=https://esd-biau.onrender.com

# Cloudflare R2 media URL base. This rewrites any legacy /media/ URLs
# returned by the API to the public R2 domain so the frontend never renders
# local backend media URLs.
VITE_R2_MEDIA_BASE=https://pub-acac0a4d8fc64b5c9268945d8a688244.r2.dev/media
